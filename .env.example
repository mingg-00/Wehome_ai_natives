# OpenAI 키가 있으면 실제 LLM으로 완성본 생성, 없으면 오프라인 스켈레톤 모드로 동작
OPENAI_API_KEY=
# 콘텐츠 생성 모델 (품질 우선이면 gpt-4o 권장, 비용 우선이면 gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# (선택) 실제 위홈 예약 API — 설정 시 MCP/도구가 샘플 대신 실데이터 사용
WEHOME_API_BASE=
WEHOME_API_KEY=

# (선택) Reddit 공식 API — 'radar' 기회탐색용. https://www.reddit.com/prefs/apps 에서
# 앱 생성(script 또는 web app) 후 client id/secret 입력. 미설정 시 비인증 폴백(차단될 수 있음).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# (선택) SNS 자사계정 자동게시 — 미설정 시 dry-run 미리보기. 각 플랫폼 개발자앱+토큰 필요.
# X(Twitter): OAuth 1.0a 정적 토큰 4종(권장·만료없음). App→Keys and tokens, 권한 Read and Write
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=              # (대안) OAuth2 user token (만료형). OAuth1.0a 4종 있으면 그게 우선.
META_ACCESS_TOKEN=          # Meta Graph (Instagram/Facebook/Threads 공용)
IG_USER_ID=                 # Instagram Business 계정 ID (이미지 URL 필요)
FB_PAGE_ID=                 # Facebook 페이지 ID
THREADS_USER_ID=            # Threads 사용자 ID
PINTEREST_TOKEN=            # Pinterest API 토큰 (이미지 URL 필요)
PINTEREST_BOARD_ID=
