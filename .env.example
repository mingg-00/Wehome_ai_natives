# Copy this file to .env and fill in only the values you need.
# Defaults below favor free/local execution before paid APIs.

# Director / storyboard generation
DIRECTOR_PROVIDER=local_template
DIRECTOR_FALLBACK_ENABLED=true
DIRECTOR_FALLBACK_PROVIDER=local_template
DIRECTOR_DAILY_API_LIMIT=0
DIRECTOR_API_USAGE_PATH=output/director_api_usage.json
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=4000

# Local rendering / paid video API
VIDEO_PROVIDER=local
VEO_API_KEY=
VEO_MODEL=veo-3.1-generate-preview
VEO_ASPECT_RATIO=9:16
VEO_RESOLUTION=720p
VEO_DURATION_SECONDS=8
VEO_POLL_INTERVAL_SECONDS=10
VEO_TIMEOUT_SECONDS=600

# Voice
TTS_PROVIDER=gtts
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Music
MUSIC_PROVIDER=local
MUSIC_API_KEY=
MUSIC_API_URL=
MUSIC_MODEL=sudo

# Request and retry behavior
REQUEST_TIMEOUT_SECONDS=20
STORYBOARD_RETRY_ATTEMPTS=3
STORYBOARD_RETRY_BACKOFF_SECONDS=1.5
DISCORD_RETRY_ATTEMPTS=3
DISCORD_RETRY_BACKOFF_SECONDS=1.5

# Paths
ASSETS_DIR=assets
AUDIO_DIR=output/temp_audio
VIDEO_DIR=output/final_video
LOCAL_VIDEO_WIDTH=1080
LOCAL_VIDEO_HEIGHT=1920
LOCAL_VIDEO_MOTION_ENABLED=true
IMAGE_DOWNLOAD_MAX_BYTES=15728640
BGM_DIR=assets/bgm
BGM_VOLUME=0.18
STORYBOARD_CACHE_PATH=output/storyboard_cache.json
STORYBOARD_CACHE_ENABLED=true
STORYBOARD_FORCE_REFRESH=false
COMPANY_PROFILE_OUTPUT_PATH=output/company_profiles/company_profile.json

# Company crawl input
COMPANY_BRAND_NAME=
COMPANY_SOURCE_URLS=
VIDEO_USER_REQUIREMENTS=
COMPANY_CRAWL_TIMEOUT_SECONDS=15
COMPANY_MAX_PAGES=3
COMPANY_CRAWL_CONTINUE_ON_ERROR=true
COMPANY_BODY_MAX_CHARS=1200
COMPANY_SUMMARY_MAX_POINTS=10
COMPANY_IMAGE_MAX_URLS=12

# Delivery
DISCORD_WEBHOOK_URL=
